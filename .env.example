# ===== Server =====
PORT=5000
CORS_ORIGIN=http://localhost:3000

# ===== Database (PostgreSQL via Prisma) =====
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/nexwapi?schema=public

# ===== Auth =====
JWT_SECRET=change_this_to_a_long_random_string
DEMO_EMAIL=admin@nexwapi.com
DEMO_PASSWORD=admin123

# ===== WhatsApp Cloud API (Meta) =====
WHATSAPP_API_VERSION=v22.0
WHATSAPP_PHONE_NUMBER_ID=123456789012345
WHATSAPP_WABA_ID=your_whatsapp_business_account_id
WHATSAPP_ACCESS_TOKEN=EAAG...your_permanent_token
WHATSAPP_APP_SECRET=your_app_secret
WHATSAPP_VERIFY_TOKEN=any_random_string_you_choose
