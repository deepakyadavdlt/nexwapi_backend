# ===== Server =====
PORT=5000
CORS_ORIGIN=http://localhost:3000

# ===== Database (PostgreSQL via Prisma) =====
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/nexwapi?schema=public

# ===== Auth =====
JWT_SECRET=change_this_to_a_long_random_string

# ===== Super Admin (auto-created on server start) =====
ADMIN_EMAIL=admin@nexwapi.com
ADMIN_PASSWORD=change_this_strong_password
ADMIN_NAME=Super Admin

# ===== Razorpay (client upgrade / payments) =====
# dashboard.razorpay.com -> Settings -> API Keys -> Generate Key
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
# Webhook: Razorpay Dashboard -> Settings -> Webhooks. URL: <backend>/api/billing/webhook
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ===== WhatsApp Cloud API / Meta (platform-level for Embedded Signup) =====
# Meta Developer Console: https://developers.facebook.com/
#
# 1) Create a Meta App → type "Business"
# 2) Add product: WhatsApp
# 3) Add product: Facebook Login for Business (for Embedded Signup)
# 4) Create an Embedded Signup configuration → copy Config ID
# 5) App settings → Basic → copy App ID + App Secret
# 6) WhatsApp → API Setup → (optional) system-user permanent token for your own test number
# 7) Webhooks → Callback URL: https://YOUR_API/api/whatsapp/webhook
#    Verify token: same as WHATSAPP_VERIFY_TOKEN below
#    Subscribe fields: messages, message_template_status_update
#
# For SaaS multi-tenant: each CLIENT connects their own WABA via Embedded Signup.
# Platform env holds YOUR Meta App credentials; per-client tokens go in WhatsAppAccount table.

WHATSAPP_API_VERSION=v22.0
WHATSAPP_APP_ID=your_meta_app_id
WHATSAPP_APP_SECRET=your_app_secret
# REQUIRED for Facebook Embedded Signup (client Connect with Facebook):
# Meta App → WhatsApp → Embedded Signup → create configuration → copy Config ID
WHATSAPP_CONFIG_ID=your_embedded_signup_config_id
WHATSAPP_VERIFY_TOKEN=any_random_string_you_choose

# Optional: your own test number (platform fallback). Client numbers stored in DB.
WHATSAPP_PHONE_NUMBER_ID=123456789012345
WHATSAPP_WABA_ID=your_whatsapp_business_account_id
WHATSAPP_ACCESS_TOKEN=EAAG...your_permanent_token

# Public API URL (used in webhook copy + OAuth). Production example:
PUBLIC_API_URL=https://api.nexwapi.com
# Must match Meta App → Facebook Login → Valid OAuth Redirect URIs
WHATSAPP_REDIRECT_URI=https://nexwapi.com/dashboard/whatsapp
