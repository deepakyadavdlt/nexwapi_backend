// Prisma schema — multi-tenant Nexwapi SaaS (PostgreSQL)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPER_ADMIN
  OWNER
  ADMIN
  AGENT
  MEMBER
}

enum CompanyStatus {
  TRIAL
  ACTIVE
  SUSPENDED
  EXPIRED
}

// Plan keys used in billing + feature gates
// trial | starter (₹499) | growth (₹999) | expired
enum PlanKey {
  trial
  starter
  growth
  expired
}

model Company {
  id             String        @id @default(cuid())
  name           String
  slug           String        @unique
  email          String?
  phone          String?
  website        String?
  status         CompanyStatus @default(TRIAL)
  plan           PlanKey       @default(trial)
  trialEndsAt    DateTime?
  trialStartedAt DateTime?
  upgradedAt     DateTime?
  suspendedAt    DateTime?
  suspendReason  String?
  lastActiveAt   DateTime?
  chatbotUsed    Boolean       @default(false)
  // Wallet & messaging credits (1 credit ≈ 1 outbound message by default)
  walletBalancePaise Int       @default(0) // rupees stored as paise
  messageCredits     Int       @default(500) // trial starter credits
  freeAccess         Boolean   @default(false) // Super Admin grant — no payment required
  freeAccessNote     String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  users            User[]
  payments         Payment[]
  subscription     Subscription?
  whatsappAccounts WhatsAppAccount[]
  agents           Agent[]
  contacts         Contact[]
  messages         Message[]
  templates        Template[]
  campaigns        Campaign[]
  automations      Automation[]
  flows            Flow[]
  drips            Drip[]
  segments         Segment[]
  products         Product[]
  labels           Label[]
  apiKeys          ApiKey[]
  setting          Setting?
  couponsRedemptions CouponRedemption[]
  usage            Usage[]
  auditLogs        AuditLog[]
  tickets          Ticket[]
  walletTxns       WalletTransaction[]
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  password     String?
  phone        String?
  role         UserRole  @default(OWNER)
  isActive     Boolean   @default(true)
  companyId    String?
  company      Company?  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lastLoginAt  DateTime?
  lastActiveAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  payments     Payment[]
  tickets      Ticket[]  @relation("TicketUser")

  @@index([companyId])
}

model Subscription {
  id           String   @id @default(cuid())
  companyId    String   @unique
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  plan         PlanKey  @default(trial)
  status       String   @default("active") // active | cancelled | past_due
  trialEndsAt  DateTime?
  activatedAt  DateTime?
  expiresAt    DateTime?
  amount       Int      @default(0) // paise
  currency     String   @default("INR")
  billingCycle String   @default("monthly")
  autoRenew    Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Plan {
  id            String   @id @default(cuid())
  key           PlanKey  @unique
  name          String
  amount        Int // paise
  currency      String   @default("INR")
  inbox         Boolean  @default(true)
  campaign      Boolean  @default(true)
  chatbot       Boolean  @default(true)
  automation    Boolean  @default(true)
  api           Boolean  @default(false)
  unlimitedAgents Boolean @default(false)
  agentLimit    Int      @default(3)
  contactLimit  Int      @default(1000)
  messageLimit  Int      @default(5000)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model WhatsAppAccount {
  id                 String    @id @default(cuid())
  companyId          String
  company            Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  businessId         String?
  wabaId             String?
  phoneNumberId      String?
  phoneNumber        String?
  displayPhoneNumber String?
  businessName       String?
  verifiedName       String?
  accessToken        String?
  refreshToken       String?
  tokenExpiresAt     DateTime?
  qualityRating      String? // GREEN | YELLOW | RED | UNKNOWN
  messagingLimit     String? // TIER_1K | TIER_10K | TIER_100K | UNLIMITED
  verificationStatus String? // verified | unverified | pending
  webhookStatus      String   @default("pending") // pending | connected | error
  status             String   @default("disconnected") // connected | disconnected | error
  isConnected        Boolean  @default(false)
  isDefault          Boolean  @default(true)
  verifyToken        String?
  appSecret          String?
  lastWebhookAt      DateTime?
  lastSyncAt         DateTime?
  lastError          String?
  connectedAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([companyId])
  @@index([phoneNumberId])
}

model Payment {
  id                String   @id @default(cuid())
  userId            String?
  user              User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  companyId         String?
  company           Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  plan              PlanKey  @default(growth)
  type              String   @default("plan") // plan | wallet_recharge | admin_grant
  amount            Int // paise
  currency          String   @default("INR")
  status            String   @default("created") // created | pending | paid | failed | refunded
  creditsAdded      Int      @default(0)
  razorpayOrderId   String?  @unique
  razorpayPaymentId String?
  invoiceNo         String?
  couponCode        String?
  refundId          String?
  paidAt            DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
  @@index([companyId])
  @@index([status])
  @@index([type])
}

// Money in/out of client wallet + message credit ledger
model WalletTransaction {
  id           String   @id @default(cuid())
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  type         String // credit | debit
  reason       String // recharge | plan | admin_grant | message_send | message_recv | adjust
  amountPaise  Int      @default(0) // wallet money change (+/-)
  creditsDelta Int      @default(0) // message credits change (+/-)
  balanceAfter Int      @default(0) // walletBalancePaise after txn
  creditsAfter Int      @default(0) // messageCredits after txn
  meta         Json?
  createdBy    String? // userId or "system"
  createdAt    DateTime @default(now())

  @@index([companyId, createdAt])
}

// Global SaaS pricing (Super Admin editable)
model PlatformSetting {
  id                String   @id @default("default")
  // How many message credits ₹1 (100 paise) buys
  creditsPerRupee   Int      @default(10)
  // Credits charged per outbound / inbound message
  creditPerOutbound Int      @default(1)
  creditPerInbound  Int      @default(0)
  trialCredits      Int      @default(500)
  starterCredits    Int      @default(5000)
  growthCredits     Int      @default(20000)
  updatedAt         DateTime @updatedAt
}

model Coupon {
  id            String   @id @default(cuid())
  code          String   @unique
  description   String   @default("")
  discountPct   Int      @default(0) // 0-100
  freeDays      Int      @default(0) // e.g. FREE30
  planKey       PlanKey? // optional: only for a specific plan
  maxRedemptions Int?
  redeemedCount Int      @default(0)
  active        Boolean  @default(true)
  expiresAt     DateTime?
  createdAt     DateTime @default(now())
  redemptions   CouponRedemption[]
}

model CouponRedemption {
  id        String   @id @default(cuid())
  couponId  String
  coupon    Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([couponId, companyId])
}

model Usage {
  id             String  @id @default(cuid())
  companyId      String
  company        Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  messagesSent   Int     @default(0)
  messagesRecv   Int     @default(0)
  campaignsCount Int     @default(0)
  apiCalls       Int     @default(0)
  month          Int
  year           Int

  @@unique([companyId, month, year])
}

model AuditLog {
  id        String   @id @default(cuid())
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  userId    String?
  action    String
  entity    String
  entityId  String?
  meta      Json?
  ip        String?
  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([createdAt])
}

model Ticket {
  id        String   @id @default(cuid())
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  userId    String?
  user      User?    @relation("TicketUser", fields: [userId], references: [id], onDelete: SetNull)
  subject   String
  body      String   @default("")
  status    String   @default("open") // open | pending | closed
  priority  String   @default("normal")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

model Agent {
  id        String    @id @default(cuid())
  companyId String
  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  email     String
  role      String    @default("Agent")
  color     String    @default("#25D366")
  createdAt DateTime  @default(now())
  contacts  Contact[]

  @@unique([companyId, email])
  @@index([companyId])
}

model Note {
  id        String   @id @default(cuid())
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  contactId String
  text      String
  author    String   @default("You")
  createdAt DateTime @default(now())

  @@index([contactId])
}

model Contact {
  id              String    @id @default(cuid())
  companyId       String
  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name            String
  phone           String
  tags            String[]  @default([])
  optedIn         Boolean   @default(true)
  color           String    @default("#25D366")
  createdAt       DateTime  @default(now())
  messages        Message[]
  notes           Note[]
  assignedAgent   Agent?    @relation(fields: [assignedAgentId], references: [id])
  assignedAgentId String?
  activeFlowId    String?
  activeFlowStep  String?
  attributes      Json      @default("{}")
  chatStatus      String    @default("open")
  labels          String[]  @default([])

  @@unique([companyId, phone])
  @@index([companyId])
}

model Event {
  id        String   @id @default(cuid())
  contactId String
  type      String
  text      String
  createdAt DateTime @default(now())

  @@index([contactId])
}

model Label {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  color     String   @default("#25D366")
  createdAt DateTime @default(now())

  @@unique([companyId, name])
  @@index([companyId])
}

model Drip {
  id          String           @id @default(cuid())
  companyId   String
  company     Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name        String
  enabled     Boolean          @default(true)
  steps       Json             @default("[]")
  createdAt   DateTime         @default(now())
  enrollments DripEnrollment[]

  @@index([companyId])
}

model DripEnrollment {
  id          String   @id @default(cuid())
  drip        Drip     @relation(fields: [dripId], references: [id], onDelete: Cascade)
  dripId      String
  contactId   String
  currentStep Int      @default(0)
  nextAt      DateTime
  status      String   @default("active")
  createdAt   DateTime @default(now())

  @@index([status, nextAt])
}

model Segment {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  tags      String[] @default([])
  match     String   @default("any")
  createdAt DateTime @default(now())

  @@index([companyId])
}

model Product {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name        String
  price       String   @default("")
  description String   @default("")
  imageUrl    String   @default("")
  createdAt   DateTime @default(now())

  @@index([companyId])
}

model Setting {
  id           String   @id @default(cuid())
  companyId    String   @unique
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  awayEnabled  Boolean  @default(false)
  awayMessage  String   @default("Thanks for messaging! We're away right now and will reply during business hours.")
  hoursStart   Int      @default(9)
  hoursEnd     Int      @default(18)
  days         String[] @default(["Mon", "Tue", "Wed", "Thu", "Fri"])
  businessName String   @default("Nexwapi")
  autoAssign   Boolean  @default(false)
  webhookUrl   String   @default("")
  csatEnabled  Boolean  @default(false)
  csatMessage  String   @default("Thanks for chatting with us! How would you rate your experience?")
  updatedAt    DateTime @updatedAt
}

model ApiKey {
  id         String    @id @default(cuid())
  companyId  String
  company    Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name       String
  key        String
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?

  @@unique([companyId, key])
  @@index([companyId])
  @@index([key])
}

model Flow {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name        String
  triggerType String   @default("keyword")
  trigger     String   @default("")
  enabled     Boolean  @default(true)
  steps       Json     @default("[]")
  createdAt   DateTime @default(now())

  @@index([companyId])
}

model Message {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  waId      String?  @unique
  contact   Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  contactId String
  direction String
  type      String   @default("text")
  text      String
  mediaUrl  String?
  filename  String?
  status    String   @default("sent")
  at        DateTime @default(now())

  @@index([contactId])
  @@index([companyId])
}

model Template {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  category  String   @default("Utility")
  language  String   @default("en")
  status    String   @default("pending")
  body      String
  format    String   @default("text")
  cards     Json?
  createdAt DateTime @default(now())

  @@unique([companyId, name])
  @@index([companyId])
}

model QuickReply {
  id        String   @id @default(cuid())
  companyId String?
  title     String
  text      String
  createdAt DateTime @default(now())

  @@index([companyId])
}

model Automation {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name      String
  keyword   String   @default("")
  matchType String   @default("contains")
  reply     String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([companyId])
}

model Campaign {
  id          String    @id @default(cuid())
  companyId   String
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name        String
  template    String
  audience    String    @default("All contacts")
  recipients  Int       @default(0)
  sent        Int       @default(0)
  delivered   Int       @default(0)
  read        Int       @default(0)
  replied     Int       @default(0)
  status      String    @default("scheduled")
  scheduledAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([companyId])
}
